          "type": "option"
        },
        "ci": {
          "description": "Disable prompts and require non-interactive behavior.",
          "name": "ci",
          "allowNo": false,
          "type": "boolean"
        },
        "json": {
          "description": "Emit machine-readable JSON output.",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
