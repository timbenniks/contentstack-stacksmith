{
  "name": "simple-blog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf .contentstack",
    "build-models": "pnpm --filter @timbenniks/contentstack-stacksmith-cli exec csdx stacksmith:build --cwd .",
    "plan-models": "pnpm --filter @timbenniks/contentstack-stacksmith-cli exec csdx stacksmith:plan --cwd .",
    "diff-models": "pnpm --filter @timbenniks/contentstack-stacksmith-cli exec csdx stacksmith:diff --cwd .",
    "docs-models": "pnpm --filter @timbenniks/contentstack-stacksmith-cli exec csdx stacksmith:docs --cwd ."
  },
  "dependencies": {
    "@timbenniks/contentstack-stacksmith": "workspace:*"
  }
}
